# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit it.

# --- Supabase ---
# Project URL: Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/public key: safe to ship in browser; RLS gates everything.
VITE_SUPABASE_ANON_KEY=eyJ...

# Service role key: server-only. NEVER prefix with VITE_ or it leaks to browser.
# Used by Edge Functions and local migration scripts.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Cloudinary ---
# Cloud name: shown at top of Cloudinary Dashboard
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name

# Unsigned upload preset: Settings > Upload > Add upload preset (Signing Mode: Unsigned)
VITE_CLOUDINARY_UPLOAD_PRESET=stayops_unsigned

# --- Twilio (Module 11 staff Phone OTP, Module 3 WhatsApp) — fill when needed ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# --- App config ---
ICAL_SYNC_INTERVAL_MINUTES=15
